<Page x:Class="TestAppDiplom.Pages.TestResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Резульат теста">

    <Grid Background="#F0F0F0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#007BFF" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="txtTestName" 
                           FontSize="18" FontWeight="Bold" Foreground="White"/>

                <Button Grid.Column="1" x:Name="btnBack" 
                        Content="Вернуться к тестам" Background="White" 
                        Foreground="#007BFF" Padding="15,8" Cursor="Hand"
                        Click="btnBack_Click"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Общий результат -->
                <Border Background="White" CornerRadius="10" Padding="25" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                                   Text="Результат тестирования" 
                                   FontSize="20" FontWeight="Bold" 
                                   Foreground="#007BFF" Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock x:Name="txtScore" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock x:Name="txtPercentage" FontSize="18" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtStatus" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtTimeSpent" FontSize="14" Foreground="Gray" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Grid.Column="1" 
                                x:Name="StatusBorder" Width="100" Height="100" 
                                CornerRadius="50" Background="#28A745" 
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="txtStatusIcon" Text="✓" 
                                       FontSize="48" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Детали по вопросам -->
                <Border Background="White" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Детализация ответов" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="#007BFF" Margin="0,0,0,15"/>

                        <ListView x:Name="lvQuestions" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding QuestionNumber}" 
                                                           FontWeight="Bold" Margin="0,0,10,0"/>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding QuestionText}" 
                                                           TextWrapping="Wrap"/>

                                                <Border Grid.Column="2" 
                                                        x:Name="ResultIndicator" 
                                                        Width="20" Height="20" CornerRadius="10"
                                                        Margin="10,0,0,0"
                                                        Loaded="ResultIndicator_Loaded"/>
                                            </Grid>

                                            <StackPanel Margin="20,10,0,0">
                                                <TextBlock Text="Ваш ответ:" FontWeight="SemiBold" Foreground="Gray"/>
                                                <TextBlock x:Name="txtUserAnswer" 
                                                           Text="{Binding UserAnswer}" 
                                                           TextWrapping="Wrap" Margin="0,5"
                                                           Loaded="txtUserAnswer_Loaded"/>
                                                <TextBlock Text="Правильный ответ:" FontWeight="SemiBold" Foreground="Gray"/>
                                                <TextBlock x:Name="txtCorrectAnswer" 
                                                           Text="{Binding CorrectAnswer}" 
                                                           TextWrapping="Wrap" Margin="0,5"
                                                           Loaded="txtCorrectAnswer_Loaded"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
