<Page x:Class="TestAppDiplom.Pages.TeacherGroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
        d:DesignHeight="600" d:DesignWidth="800"
      Title="Мои группы">

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#007BFF" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Управление группами" 
                           FontSize="20" FontWeight="Bold" Foreground="White"/>

                <Button x:Name="btnBack" Grid.Column="1" Content="Назад" 
                        Background="White" Foreground="#007BFF"
                        Padding="15,8" Click="btnBack_Click"  Cursor="Hand"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Доступные группы" FontSize="18" FontWeight="Bold" 
                               Foreground="#007BFF" Margin="0,0,0,15"/>

                    <ListView x:Name="lvAvailableGroups" 
                              SelectionMode="Single"
                              SelectionChanged="lvAvailableGroups_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название" Width="100" 
                                                DisplayMemberBinding="{Binding GroupName}"/>
                                <GridViewColumn Header="Специальность" Width="150" 
                                                DisplayMemberBinding="{Binding Specialty}"/>
                                <GridViewColumn Header="Курс" Width="50" 
                                                DisplayMemberBinding="{Binding Course}"/>
                                <GridViewColumn Header="Описание" Width="300" 
                                                DisplayMemberBinding="{Binding Description}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button x:Name="btnAddGroup" Content="Добавить выбранную группу" 
                            Background="#28A745" Foreground="White"
                            Padding="15,8" Margin="0,15,0,0" Cursor="Hand"
                            IsEnabled="False" Click="btnAddGroup_Click"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Мои группы" FontSize="18" FontWeight="Bold" 
                               Foreground="#007BFF" Margin="0,0,0,15"/>

                    <ListView x:Name="lvMyGroups">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название" Width="100" 
                                                DisplayMemberBinding="{Binding GroupName}"/>
                                <GridViewColumn Header="Специальность" Width="150" 
                                                DisplayMemberBinding="{Binding Specialty}"/>
                                <GridViewColumn Header="Курс" Width="50" 
                                                DisplayMemberBinding="{Binding Course}"/>
                                <GridViewColumn Header="Описание" Width="300" 
                                                DisplayMemberBinding="{Binding Description}"/>
                                <GridViewColumn Header="Действия" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnRemoveGruop" Content="Удалить" 
                                                    Background="#DC3545" Foreground="White"
                                                    Padding="8,3" Cursor="Hand"
                                                    Tag="{Binding GroupID}"
                                                    Click="btnRemoveGruop_Click"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
