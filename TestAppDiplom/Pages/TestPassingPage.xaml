<Page x:Class="TestAppDiplom.Pages.TestPassingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Прохождение теста">

    <Grid Background="#F0F0F0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с информацией о тесте -->
        <Border Grid.Row="0" Background="#007BFF" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="txtTestName" FontSize="18" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtTestInfo" Foreground="White" FontSize="12"/>
                </StackPanel>

                <TextBlock x:Name="txtTimer" Grid.Column="1" 
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="20,0"/>

                <Button x:Name="btnFinishTest" Grid.Column="2" 
                        Content="Завершить тест" Background="#DC3545" 
                        Foreground="White" Padding="15,8" Cursor="Hand"
                        Click="btnFinishTest_Click"/>
            </Grid>
        </Border>

        <!-- Область вопросов -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Прогресс -->
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="txtProgress" Grid.Column="0" 
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,15,0"/>

                        <ProgressBar x:Name="progressBar" Grid.Column="1" 
                                     Height="20" Minimum="0" Maximum="100"/>
                    </Grid>
                </Border>

                <!-- Текущий вопрос -->
                <Border Background="White" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock x:Name="txtQuestionNumber" FontSize="14" 
                                   Foreground="Gray" Margin="0,0,0,5"/>

                        <TextBlock x:Name="txtQuestionText" FontSize="16" 
                                   FontWeight="SemiBold" TextWrapping="Wrap" 
                                   Margin="0,0,0,20"/>

                        <TextBlock x:Name="txtQuestionType" FontSize="12" 
                                   Foreground="#007BFF" Margin="0,0,0,10"/>

                        <!-- Контейнер для ответов -->
                        <StackPanel x:Name="spAnswers" Margin="0,10,0,20"/>

                        <!-- Навигация по вопросам -->
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPrevious" Grid.Column="0" 
                                    Content="← Предыдущий" Background="#6C757D" 
                                    Foreground="White" Padding="15,8" Width="150"
                                    HorizontalAlignment="Left" Cursor="Hand"
                                    Click="btnPrevious_Click"/>

                            <TextBlock x:Name="txtQuestionCounter" Grid.Column="1" 
                                       VerticalAlignment="Center" FontSize="14"/>

                            <Button x:Name="btnNext" Grid.Column="2" 
                                    Content="Следующий →" Background="#007BFF" 
                                    Foreground="White" Padding="15,8" Width="150"
                                    HorizontalAlignment="Right" Cursor="Hand"
                                    Click="btnNext_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#E9ECEF" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Для ответа на вопросы с множественным выбором используйте Ctrl+клик" 
                           Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
