<Page x:Class="TestAppDiplom.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="600"
      Title="Авторизация">

    <Grid Background="#F0F0F0">

        <Border Width="400" Height="320" Background="White" CornerRadius="10" 
                BorderBrush="#007BFF" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="20">
                <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" 
                           Foreground="#007BFF" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин:" Margin="0,5"/>
                <TextBox x:Name="txtUsername" Height="35" Padding="5" 
                         BorderBrush="#CCCCCC" BorderThickness="1"/>

                <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Padding="5" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                <Button x:Name="btnLogin" Content="Войти" Height="40" 
                        Background="#007BFF" Foreground="White" FontSize="16"
                        Margin="0,20,0,10" Cursor="Hand" Click="btnLogin_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Нет аккаунта? "/>
                    <Button x:Name="btnGoToRegister" Content="Зарегистрироваться" 
                            Background="Transparent" Foreground="#007BFF" 
                            Cursor="Hand" BorderThickness="0" 
                             Click="btnGoToRegister_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Page>
