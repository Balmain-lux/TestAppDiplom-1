<Page x:Class="TestAppDiplom.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="600"
      Title="Регистрация">

    <Grid Background="#F0F0F0">

        
            <Border Width="450" Background="White" CornerRadius="10" 
                    BorderBrush="#007BFF" BorderThickness="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <StackPanel Margin="25">
                    <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" 
                               Foreground="#007BFF" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Логин:" Margin="0,5"/>
                    <TextBox x:Name="txtUsername" Height="35" Padding="5" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="35" Padding="5" 
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Подтверждение пароля:" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="35" Padding="5" 
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Имя:" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtFirstName" Height="35" Padding="5" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Фамилия:" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtLastName" Height="35" Padding="5" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Email:" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtEmail" Height="35" Padding="5" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Роль:" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbRole" Height="35" 
                              DisplayMemberPath="RoleName" 
                              SelectedValuePath="RoleID"/>

                    <Button x:Name="btnRegister" Content="Зарегистрироваться" Height="40" 
                            Background="#007BFF" Foreground="White" FontSize="16"
                            Margin="0,20,0,10" Cursor="Hand" Click="btnRegister_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Уже есть аккаунт? "/>
                        <Button x:Name="btnGoToLogin" Content="Войти" 
                                Background="Transparent" Foreground="#007BFF" 
                                Cursor="Hand" BorderThickness="0" 
                                 Click="btnGoToLogin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
 

    </Grid>
</Page>
