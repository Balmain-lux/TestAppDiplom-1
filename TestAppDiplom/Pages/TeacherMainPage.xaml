<Page x:Class="TestAppDiplom.Pages.TeacherMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestAppDiplom.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Преподаватель - Главная">

    <Grid Background="#F0F0F0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#007BFF" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Панель преподавателя" 
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnManageGroups" Content="Мои группы" 
                             Background="#FFC107" Foreground="White"
                             Padding="10,5" Margin="0,0,10,0" Cursor="Hand"
                            Click="btnManageGroups_Click"/>
                    <TextBlock x:Name="txtUserInfo" Text="Пользователь" 
                               FontSize="14" Foreground="White" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" 
                            Background="White" Foreground="#007BFF" 
                            Padding="10,5" Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <TabControl Grid.Row="1" Margin="20" Background="White">
            <!-- Вкладка с тестами -->
            <TabItem Header="Управление тестами" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnAddTest" Content="+ Добавить тест" 
                                Background="#28A745" Foreground="White"
                                Padding="15,5" Cursor="Hand" Click="btnAddTest_Click"/>
                    </StackPanel>

                    <ListView x:Name="lvTests" Grid.Row="1" ItemsSource="{Binding Tests}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название" Width="200" 
                                                DisplayMemberBinding="{Binding TestName}"/>
                                <GridViewColumn Header="Описание" Width="250" 
                                                DisplayMemberBinding="{Binding Description}"/>
                                <GridViewColumn Header="Предмет" Width="120" 
                                                DisplayMemberBinding="{Binding Subject.SubjectName}"/>
                                <GridViewColumn Header="Время (мин)" Width="80" 
                                                DisplayMemberBinding="{Binding TimeLimit}"/>
                                <GridViewColumn Header="Статус" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="txtStatus" 
                                                       Text="{Binding IsActive}"
                                                       Loaded="txtStatus_Loaded"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Действия" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnEditTest" Content="Ред." 
                                                        Background="#FFC107" Foreground="White"
                                                        Padding="5" Margin="0,0,5,0" Cursor="Hand"
                                                        Tag="{Binding TestID}" 
                                                        Click="btnEditTest_Click"/>
                                                <Button x:Name="btnDeleteTest" Content="Удал." 
                                                        Background="#DC3545" Foreground="White"
                                                        Padding="5" Cursor="Hand"
                                                        Tag="{Binding TestID}" 
                                                        Click="btnDeleteTest_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Вкладка с результатами -->
            <TabItem Header="Результаты студентов" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Тест:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="cmbTestFilter" Width="200" Margin="0,0,10,0"
                                  DisplayMemberPath="TestName" SelectedValuePath="TestID"
                                  SelectionChanged="cmbTestFilter_SelectionChanged"/>
                        <TextBlock Text="Студент:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="cmbStudentFilter" Width="200"
                                  DisplayMemberPath="FullName" SelectedValuePath="UserID"
                                  SelectionChanged="cmbStudentFilter_SelectionChanged"/>
                    </StackPanel>

                    <ListView x:Name="lvResults" Grid.Row="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Студент" Width="150" 
                                                DisplayMemberBinding="{Binding User.LastName}"/>
                                <GridViewColumn Header="Тест" Width="200" 
                                                DisplayMemberBinding="{Binding Test.TestName}"/>
                                <GridViewColumn Header="Дата" Width="120" 
                                                DisplayMemberBinding="{Binding EndTime, StringFormat=dd.MM.yyyy}"/>
                                <GridViewColumn Header="Результат" Width="80" 
                                                DisplayMemberBinding="{Binding PercentageScore, StringFormat={}{0:F1}%}"/>
                                <GridViewColumn Header="Статус" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="txtStatusResult" 
                                                       Text="{Binding IsPassed}"
                                                       Loaded="txtStatusResult_Loaded"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Действия" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnViewStudentResult" Content="Просмотр" 
                                                    Background="#007BFF" Foreground="White"
                                                    Padding="5" Cursor="Hand"
                                                    Tag="{Binding ResultID}" 
                                                    Click="btnViewStudentResult_Click"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Page>
